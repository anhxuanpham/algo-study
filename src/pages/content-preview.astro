---
import StatusBadge from '../components/ui/status-badge.astro';
import BaseLayout from '../layouts/base-layout.astro';
import { withBase } from '../config/site';
import { getPreviewLessons, getTopics } from '../lib/content/queries';

const lessons = await getPreviewLessons();
const topics = new Map((await getTopics()).map((entry) => [entry.id, entry]));
const statusTone = {
  planned: 'neutral',
  draft: 'neutral',
  review: 'warning',
  published: 'ready',
} as const;
---

<BaseLayout
  title="Content reviewer preview"
  description="Danh sách nội dung đang được soạn thảo và review nội bộ."
  robots="noindex,nofollow"
>
  <section class="preview-index site-frame" data-pagefind-ignore>
    <header class="preview-index__header">
      <p class="eyebrow">Internal reviewer preview</p>
      <h1>Nội dung đang được review</h1>
      <p>
        Các route này dùng content collection thật cho reviewer nội bộ. Learner-facing publication
        nằm ở <a href={withBase('/learn/')}>/learn/</a> cho nội dung <code>published</code>.
      </p>
    </header>

    {
      lessons.length > 0 ? (
        <ol class="preview-list">
          {lessons.map((lesson) => {
            const topic = topics.get(lesson.data.topicId);
            return (
              <li>
                <article>
                  <div class="preview-list__meta">
                    <StatusBadge tone={statusTone[lesson.data.status]}>
                      {lesson.data.status}
                    </StatusBadge>
                    <span>{topic?.data.titleVi ?? lesson.data.topicId}</span>
                    <span>{lesson.data.estimatedMinutes} phút</span>
                  </div>
                  <h2>
                    <a href={withBase(`/content-preview/${lesson.id}/`)}>{lesson.data.titleVi}</a>
                  </h2>
                  <p class="preview-list__title-en">{lesson.data.titleEn}</p>
                  <p>{lesson.data.description}</p>
                  <p class="preview-list__id">
                    Canonical ID: <code>{lesson.id}</code>
                  </p>
                </article>
              </li>
            );
          })}
        </ol>
      ) : (
        <p>Không có lesson draft, review hoặc published để preview.</p>
      )
    }
  </section>
</BaseLayout>

<style>
  .preview-index {
    max-width: 72rem;
    padding-block: var(--space-16);
  }

  .preview-index__header {
    max-width: 66ch;
    padding-bottom: var(--space-10);
    border-bottom: 1px solid var(--border-strong);
  }

  h1 {
    margin-block: var(--space-5);
    font-size: var(--text-3xl);
    letter-spacing: var(--tracking-heading);
  }

  .preview-index__header > p:last-child {
    color: var(--ink-soft);
    font-size: var(--text-xl);
  }

  .preview-list {
    display: grid;
    gap: var(--space-6);
    padding: 0;
    margin-block: var(--space-10) 0;
    list-style: none;
  }

  .preview-list article {
    padding: var(--space-8);
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .preview-list__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    color: var(--muted);
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: 500;
  }

  h2 {
    margin: var(--space-5) 0 var(--space-2);
    font-size: var(--text-2xl);
  }

  h2 a {
    color: var(--ink);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
  }

  .preview-list__title-en,
  .preview-list__id {
    color: var(--muted);
    font-size: var(--text-sm);
  }

  .preview-list__title-en {
    font-family: var(--font-ui);
    font-weight: 500;
  }

  .preview-list__id {
    margin-bottom: 0;
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }
</style>
