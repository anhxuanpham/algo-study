---
interface Props {
  id: string;
  items: string[];
}

const { id, items } = Astro.props;
const titleId = `${id}-title`;
---

<section class="learning-objectives" aria-labelledby={titleId}>
  <p class="eyebrow">Learning objectives</p>
  <h2 id={titleId}>Sau bài này, bạn có thể</h2>
  <ul>
    {items.map((item) => <li>{item}</li>)}
  </ul>
</section>

<style>
  .learning-objectives {
    padding: var(--space-6);
    border: 1px solid var(--border-strong);
    background: var(--surface);
  }

  h2 {
    margin-bottom: var(--space-4);
    font-size: var(--text-xl);
  }

  ul {
    margin-bottom: 0;
  }
</style>
