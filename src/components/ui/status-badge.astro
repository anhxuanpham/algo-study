---
interface Props {
  tone?: 'neutral' | 'ready' | 'warning' | 'danger';
}

const { tone = 'neutral' } = Astro.props;
---

<span class:list={['status-badge', `status-badge--${tone}`]}>
  <span aria-hidden="true" class="status-badge__mark"></span>
  <slot />
</span>

<style>
  .status-badge {
    display: inline-flex;
    min-height: 1.75rem;
    align-items: center;
    gap: 0.45rem;
    padding-inline: 0.65rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: var(--surface);
    color: var(--ink-soft);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .status-badge__mark {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--muted);
  }

  .status-badge--ready {
    border-color: var(--success);
    background: var(--success-soft);
  }

  .status-badge--ready .status-badge__mark {
    background: var(--success);
  }

  .status-badge--warning {
    border-color: var(--warning);
    background: var(--warning-soft);
  }

  .status-badge--warning .status-badge__mark {
    background: var(--warning);
  }

  .status-badge--danger {
    border-color: var(--danger);
    background: var(--danger-soft);
  }

  .status-badge--danger .status-badge__mark {
    background: var(--danger);
  }
</style>
