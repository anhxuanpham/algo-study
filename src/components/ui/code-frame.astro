---
interface Props {
  label: string;
  language?: string;
}

const { label, language = 'typescript' } = Astro.props;
---

<figure class="code-frame">
  <figcaption class="code-frame__bar">
    <span>{label}</span>
    <span>{language}</span>
  </figcaption>
  <div class="code-frame__body" tabindex="0" role="region" aria-label={`${label}, mã ${language}`}>
    <slot />
  </div>
</figure>

<style>
  .code-frame {
    max-width: 100%;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    margin: 0;
    overflow: hidden;
    background: var(--code-canvas);
    color: var(--code-ink);
  }

  .code-frame__bar {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid color-mix(in srgb, var(--code-muted), transparent 65%);
    color: var(--code-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  .code-frame__body {
    max-width: 100%;
    overflow-x: auto;
  }

  .code-frame__body :global(pre) {
    padding: var(--space-5);
    margin: 0;
    background: transparent;
    color: inherit;
    font-size: var(--text-sm);
    line-height: 1.75;
  }
</style>
