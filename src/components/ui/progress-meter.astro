---
interface Props {
  label: string;
  value: number;
  max?: number;
}

const { label, value, max = 100 } = Astro.props;
const safeValue = Math.min(Math.max(value, 0), max);
const percent = max > 0 ? Math.round((safeValue / max) * 100) : 0;
---

<div class="progress-meter">
  <div class="progress-meter__label">
    <span>{label}</span>
    <span>{percent}%</span>
  </div>
  <progress max={max} value={safeValue}>{percent}%</progress>
</div>

<style>
  .progress-meter {
    display: grid;
    gap: var(--space-2);
  }

  .progress-meter__label {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    color: var(--ink-soft);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
  }

  progress {
    width: 100%;
    height: 0.5rem;
    border: 0;
    background: var(--surface-muted);
    accent-color: var(--primary);
  }

  progress::-webkit-progress-bar {
    background: var(--surface-muted);
  }

  progress::-webkit-progress-value {
    background: var(--primary);
  }

  progress::-moz-progress-bar {
    background: var(--primary);
  }
</style>
