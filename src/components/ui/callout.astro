---
interface Props {
  title: string;
  tone?: 'note' | 'important' | 'warning';
}

const { title, tone = 'note' } = Astro.props;
---

<aside class:list={['callout', `callout--${tone}`]} aria-label={title}>
  <p class="callout__title">{title}</p>
  <div class="callout__body"><slot /></div>
</aside>

<style>
  .callout {
    position: relative;
    padding: var(--space-5) var(--space-6);
    border: 1px solid var(--border);
    border-left: 0.3rem solid var(--primary);
    background: var(--surface);
  }

  .callout--important {
    border-left-color: var(--action);
  }

  .callout--warning {
    border-left-color: var(--warning);
    background: var(--warning-soft);
  }

  .callout__title {
    margin-bottom: var(--space-2);
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .callout__body :global(:last-child) {
    margin-bottom: 0;
  }
</style>
