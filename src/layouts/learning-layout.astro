---
import BaseLayout from './base-layout.astro';

export type LearningNavigationItem = {
  href: string;
  label: string;
  current?: boolean;
};

interface Props {
  title: string;
  description?: string | undefined;
  robots?: string | undefined;
  searchable?: boolean | undefined;
  curriculumLabel?: string | undefined;
  curriculumItems?: LearningNavigationItem[] | undefined;
  outlineItems?: LearningNavigationItem[] | undefined;
}

const defaultCurriculumItems: LearningNavigationItem[] = [
  { href: '#concept', label: '01 · Khái niệm', current: true },
  { href: '#example', label: '02 · Ví dụ' },
  { href: '#checkpoint', label: '03 · Kiểm tra' },
];
const defaultOutlineItems: LearningNavigationItem[] = [
  { href: '#concept', label: 'Khái niệm' },
  { href: '#example', label: 'Ví dụ' },
  { href: '#checkpoint', label: 'Checkpoint' },
];
const {
  title,
  description,
  robots,
  searchable = true,
  curriculumLabel = 'Bài học mẫu',
  curriculumItems = defaultCurriculumItems,
  outlineItems = defaultOutlineItems,
} = Astro.props;
const hasCurriculum = curriculumItems.length > 0;
const hasOutline = outlineItems.length > 0;
---

<BaseLayout title={title} description={description} robots={robots}>
  <div class:list={['learning-shell', 'site-frame', { 'learning-shell--no-outline': !hasOutline }]}>
    {
      hasCurriculum && (
        <details class="learning-shell__curriculum-mobile">
          <summary>Chương trình học</summary>
          <nav aria-label="Chương trình học trên thiết bị nhỏ">
            <ol>
              {curriculumItems.map((item) => (
                <li>
                  <a aria-current={item.current ? 'page' : undefined} href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </details>
      )
    }

    {
      hasCurriculum && (
        <aside class="learning-shell__curriculum" aria-label="Chương trình học">
          <p class="eyebrow">Curriculum</p>
          <nav aria-label={curriculumLabel}>
            <ol>
              {curriculumItems.map((item) => (
                <li>
                  <a aria-current={item.current ? 'page' : undefined} href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )
    }

    <article
      class="learning-shell__reader"
      data-pagefind-body={searchable ? true : undefined}
      data-pagefind-ignore={searchable ? undefined : true}
    >
      <slot />
    </article>

    {
      hasOutline && (
        <aside class="learning-shell__outline" aria-label="Trong bài này">
          <p class="eyebrow">Trong bài này</p>
          <nav aria-label="Mục lục bài học">
            <ol>
              {outlineItems.map((item) => (
                <li>
                  <a aria-current={item.current ? 'location' : undefined} href={item.href}>
                    {item.label}
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )
    }
  </div>
</BaseLayout>

<style>
  .learning-shell {
    display: grid;
    grid-template-columns: minmax(11rem, 0.7fr) minmax(0, var(--reader-width)) minmax(11rem, 0.7fr);
    gap: clamp(1.5rem, 4vw, 4.5rem);
    align-items: start;
    padding-block: var(--space-12);
  }

  .learning-shell--no-outline {
    grid-template-columns: minmax(11rem, 0.7fr) minmax(0, var(--reader-width));
    justify-content: center;
  }

  .learning-shell__curriculum-mobile {
    display: none;
  }

  .learning-shell__curriculum,
  .learning-shell__outline {
    position: sticky;
    top: 6.5rem;
    min-width: 0;
    padding-top: var(--space-3);
    border-top: 1px solid var(--border-strong);
  }

  :global(.learning-shell aside ol) {
    display: grid;
    gap: var(--space-2);
    padding: 0;
    list-style: none;
  }

  :global(.learning-shell aside a) {
    display: block;
    padding: var(--space-2) 0;
    color: var(--muted);
    font-size: var(--text-sm);
    text-decoration: none;
  }

  :global(.learning-shell aside a:hover),
  :global(.learning-shell aside a[aria-current]) {
    color: var(--primary);
  }

  .learning-shell__reader {
    min-width: 0;
  }

  .learning-shell__reader :global(p),
  .learning-shell__reader :global(li) {
    color: var(--ink-soft);
    font-size: var(--text-lg);
    line-height: 1.75;
  }

  @media (max-width: 69.99rem) {
    .learning-shell,
    .learning-shell--no-outline {
      grid-template-columns: minmax(0, 1fr) minmax(12rem, 0.32fr);
      justify-content: normal;
    }

    .learning-shell--no-outline {
      grid-template-columns: minmax(0, var(--reader-width));
      justify-content: center;
    }

    .learning-shell__curriculum {
      display: none;
    }

    .learning-shell__curriculum-mobile {
      display: block;
      grid-column: 1 / -1;
      padding: var(--space-3) var(--space-4);
      border: 1px solid var(--border-strong);
      background: var(--surface);
    }

    .learning-shell__curriculum-mobile summary {
      min-height: 2.75rem;
      display: flex;
      align-items: center;
      color: var(--ink);
      cursor: pointer;
      font-family: var(--font-ui);
      font-size: var(--text-sm);
      font-weight: 700;
    }
  }

  @media (max-width: 47.99rem) {
    .learning-shell,
    .learning-shell--no-outline {
      grid-template-columns: minmax(0, 1fr);
      padding-block: var(--space-8);
    }

    .learning-shell__outline {
      position: static;
      grid-row: 1;
    }
  }
</style>
